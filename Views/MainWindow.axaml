<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TeacherDesk.ViewModels"
        xmlns:views="using:TeacherDesk.Views"
        x:Class="TeacherDesk.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="TeacherDesk">

    <DockPanel>
        <!-- Panneau latéral de navigation -->
        <Border DockPanel.Dock="Left" 
                Width="200" 
                Background="#F5F5F5"
                Padding="12"
                IsVisible="{Binding !IsFirstTime}">
            <StackPanel Spacing="8">
            <TextBlock Text="Navigation" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       Margin="0,0,0,12"/>
            
            <Button Content="Accueil" 
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Command="{Binding NavigateToHomeCommand}" />
            
            <Button Content="Calendrier" 
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Command="{Binding NavigateToCalendarCommand}" />
            
            <Button Content="Cours" 
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Command="{Binding NavigateToCoursesCommand}" />
            
            <Button Content="Écoles" 
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Command="{Binding NavigateToSchoolsCommand}" />
            </StackPanel>
        </Border>

        <!-- Contenu principal -->
        <ContentControl Content="{Binding CurrentViewModel}" Padding="16" />
    </DockPanel>

</Window>
